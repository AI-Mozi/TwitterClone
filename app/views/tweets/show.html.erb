<div class="columns">
  <div class="column is-half is-offset-one-quarter">
    <div class="box">
      <article class="media tweet">
        <div class="media-left">
          <figure class="image is-64x64">
            <%= gravatar_image_tag(@tweet.user.email, size: 64, alt: @tweet.user.name) %>
          </figure>
        </div>
        <div class="media-content">
          <div class="content">
            <strong><%= @tweet.user.name %></strong>
            <small>@<%= @tweet.user.username %></small><br />
            <p><%= @tweet.tweet %></p>
          </div>
          <% if user_signed_in? %>
          <nav class="level">
            <div class="level-left">
              <p class="parent-likes">
                <% if current_user.liked? @tweet %>
                  <%= link_to unlike_tweet_path(@tweet), method: :put, class: 'unlike_tweet' do %>
                  <span class="icon"><i class="fa fa-heart has-text-danger"></i></span>
                  <span class="vote_count"><%= @tweet.get_likes.size %></span>
                  <%end%>
                <%else%>
                  <%= link_to like_tweet_path(@tweet), method: :put, class: 'like_tweet' do %>
                  <span class="icon"><i class="fa fa-heart"></i></span>
                  <span class="vote_count"><%= @tweet.get_likes.size %></span>
                  <%end%>
                <%end%>
              </p>
            </div>
            <% if @tweet.user_id == current_user.id %>
            <div class="level-right ">
              <%= link_to edit_tweet_path(@tweet), class: "level-item" do %>
              <span class="icon"><i class="fa fa-pencil" aria-hidden="true"></i></span>
              <% end %>
              <%= link_to @tweet, class: "level-item", method: :delete , data: {confirm: "Are you sure you want to delete this tweet? "} do%>
              <span class="icon"><i class="fa fa-trash-o" aria-hidden="true"></i></span>
              <% end %>
            </div>
          </nav>
          <% end %>
          <% end %>
        </div>
      </article>
      <% if user_signed_in? %>
        <hr>
        <div class="reply">
          <%= render 'comments/form' %>
        </div>
      <%end%>
    </div>
  </div>
</div>

<div class="columns">
  <div class="column is-6 is-offset-3">
    <% @tweet.comments.each do |comment| %>
    <% if comment.id.present? %>
    <div class="box comment">
      <article class="media">
        <figure class="media-left">
          <p class="image is-64x64">
            <%= gravatar_image_tag(comment.email, size: 64, alt: comment.name) %>
          </p>
        </figure>
        <div class="media-content">
          <div class="content">
            <p>
              <strong><%= comment.name %></strong>
              <small>@<%= comment.username %></small>
              <small><%= time_ago_in_words(comment.created_at)%></small></br>
              <%= comment.body %>
            </p>
          </div>
        </div>
        <div class="media-right">
          <% if user_signed_in? %>
          <% if comment.name == current_user.name %>
          <%= link_to "Del",[comment.tweet,comment], class: "delete", method: :delete, data: {confirm: "Are you sure?"} %>
          <%end%>
          <%end%>
        </div>
      </article>
    </div>
    <% end %>
    <% end %>
  </div>
</div>